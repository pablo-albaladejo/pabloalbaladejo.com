---
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  lang?: "en";
  path: string;
  active?: "writing" | "talks" | "cv";
};

const { title, description, lang = "en", path, active } = Astro.props;
const site = "https://pabloalbaladejo.com";
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const navLink = "text-muted hover:text-ink no-underline";
const navActive = "text-ink border-b-2 border-accent pb-0.5 no-underline";
---

<!doctype html>
<html lang={lang} data-theme-setting="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Apply the persisted theme before first paint to avoid a flash of the
      // wrong palette. `theme` is "light" | "dark" | "system" (default). The
      // footer script wires the toggle button; this only sets the initial state.
      (function () {
        var setting = "system";
        try {
          setting = localStorage.getItem("theme") || "system";
        } catch (e) {}
        var dark =
          setting === "dark" ||
          (setting === "system" &&
            matchMedia("(prefers-color-scheme: dark)").matches);
        var root = document.documentElement;
        root.classList.toggle("dark", dark);
        root.dataset.themeSetting = setting;
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`${site}${path}`} />
    <link rel="alternate" hreflang="en" href={`${site}${path}`} />
    <link rel="alternate" hreflang="x-default" href={`${site}${path}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Pablo Albaladejo"
      href="/rss.xml"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${site}${path}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Pablo Albaladejo" />
    <meta property="og:locale" content="en_US" />
    {
      umamiId && (
        <script
          is:inline
          defer
          src="https://cloud.umami.is/script.js"
          data-website-id={umamiId}
        />
      )
    }
    <slot name="head" />
  </head>
  <body class="mx-auto max-w-[1100px] px-6 min-[700px]:px-8">
    <header
      class="flex items-center justify-between border-b border-line py-7"
    >
      <a href="/" class="flex items-center gap-3 text-ink no-underline">
        <span
          class="box-border inline-flex h-[34px] w-[34px] items-end justify-center rounded-[7px] bg-ink pb-1.5 font-serif text-[19px] leading-none font-semibold text-paper"
          aria-hidden="true"
          >pa<span
            class="mb-px ml-px inline-block h-[3px] w-[5px] bg-accent-br"
          ></span></span
        >
        <span class="text-[17px] font-semibold tracking-[-0.01em]"
          >Pablo Albaladejo</span
        >
      </a>
      <nav class="flex items-center gap-7 font-mono text-[13px]">
        <a href="/blog" class={active === "writing" ? navActive : navLink}
          >Writing</a
        >
        <a href="/talks" class={active === "talks" ? navActive : navLink}
          >Talks</a
        >
        <a href="/cv" class={active === "cv" ? navActive : navLink}>CV</a>
        <button
          id="theme-toggle"
          type="button"
          aria-label="Color theme: system"
          title="Color theme: system"
          class="-m-1.5 flex items-center rounded-md p-1.5 text-muted transition-colors hover:text-ink"
        >
          <svg
            class="ti ti-system h-[17px] w-[17px]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="3" width="20" height="14" rx="2"></rect>
            <path d="M8 21h8M12 17v4"></path>
          </svg>
          <svg
            class="ti ti-light h-[17px] w-[17px]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path
              d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
            ></path>
          </svg>
          <svg
            class="ti ti-dark h-[17px] w-[17px]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
        </button>
      </nav>
    </header>
    <slot />
    <script is:inline>
      // Assemble mailto links at runtime so the address never appears in the
      // static HTML (harvester bots don't run JS). Falls back to the href in
      // markup (LinkedIn) when JS is off.
      document
        .querySelectorAll("[data-email][data-domain]")
        .forEach((el) => {
          let href = "mailto:" + el.dataset.email + "@" + el.dataset.domain;
          if (el.dataset.subject)
            href += "?subject=" + encodeURIComponent(el.dataset.subject);
          el.setAttribute("href", href);
        });
    </script>
    <script is:inline>
      // Wire the header toggle: cycle System -> Light -> Dark and persist the
      // choice. The <head> script already applied the initial palette; here we
      // only update on click and keep "system" live with the OS preference.
      (function () {
        var order = ["system", "light", "dark"];
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        var mq = matchMedia("(prefers-color-scheme: dark)");
        function read() {
          try {
            return localStorage.getItem("theme") || "system";
          } catch (e) {
            return "system";
          }
        }
        function apply(setting) {
          var dark =
            setting === "dark" || (setting === "system" && mq.matches);
          var root = document.documentElement;
          root.classList.toggle("dark", dark);
          root.dataset.themeSetting = setting;
          btn.setAttribute("aria-label", "Color theme: " + setting);
          btn.title = "Color theme: " + setting;
        }
        apply(read());
        btn.addEventListener("click", function () {
          var next = order[(order.indexOf(read()) + 1) % order.length];
          try {
            localStorage.setItem("theme", next);
          } catch (e) {}
          apply(next);
        });
        mq.addEventListener("change", function () {
          if (read() === "system") apply("system");
        });
      })();
    </script>
  </body>
</html>
