---
import Base from "../layouts/Base.astro";
---

<Base
  title="Not found — Pablo Albaladejo"
  description="This page does not exist."
  lang="en"
  path="/404"
  robots="noindex, follow"
>
  <main class="mx-auto max-w-[70ch] py-32 text-center">
    <p class="mb-4 font-mono text-[15px] font-semibold tracking-[0.08em] text-faint">
      404
    </p>
    <h1
      class="text-[34px] leading-[1.15] font-bold tracking-[-0.015em] min-[700px]:text-[44px]"
    >
      Nothing here.
    </h1>
    <p class="mt-5 text-[18px] leading-[1.6] text-body">
      Try the <a
        href="/"
        class="text-accent no-underline hover:underline">home page</a
      >.
    </p>
  </main>
</Base>
