---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const site = "https://pabloalbaladejo.com";
const pageUrl = `${site}/blog/${entry.id}`;

const isoDate = entry.data.pubDate.toISOString().slice(0, 10);
const minutes = Math.max(
  1,
  Math.round(entry.body.split(/\s+/).length / 220),
);

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  author: {
    "@type": "Person",
    name: "Pablo Albaladejo",
    url: "https://pabloalbaladejo.com/",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": pageUrl,
  },
});

const faq = entry.data.faq;
const faqJsonLd = faq
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.a,
        },
      })),
    })
  : null;

const sources = entry.data.sources;
const category = entry.data.category;
---

<Base
  title={entry.data.title}
  description={entry.data.description}
  lang="en"
  path={`/blog/${entry.id}`}
  active="writing"
>
  <script
    type="application/ld+json"
    set:html={articleJsonLd}
    slot="head"
  />
  {
    faqJsonLd && (
      <script
        type="application/ld+json"
        set:html={faqJsonLd}
        slot="head"
      />
    )
  }

  <main class="mx-auto max-w-[70ch] pt-16 pb-24 min-[700px]:pt-[88px]">
    <header>
      <p class="mb-5 font-mono text-[12.5px] text-faint">
        {category && <span class="text-accent">{category}</span>}
        {category && <span> · </span>}
        <time datetime={entry.data.pubDate.toISOString()}>{isoDate}</time>
        <span> · </span>
        {minutes} min read
      </p>
      <h1
        class="text-[34px] leading-[1.15] font-bold tracking-[-0.015em] text-pretty min-[700px]:text-[44px]"
      >
        {entry.data.title}
      </h1>
      <p
        class="mt-6 border-b border-line pb-8 text-[21px] leading-[1.55] text-muted italic text-pretty"
      >
        {entry.data.description}
      </p>
    </header>

    <article class="prose-article mt-10">
      <Content />
    </article>

    {
      faq && (
        <section class="mt-16">
          <h2 class="mb-6 font-mono text-[15px] font-semibold tracking-[0.08em] text-faint">
            FAQ
          </h2>
          <dl class="space-y-7">
            {faq.map((item) => (
              <div>
                <dt class="text-[18.5px] font-bold text-ink">{item.q}</dt>
                <dd class="mt-2 text-body">{item.a}</dd>
              </div>
            ))}
          </dl>
        </section>
      )
    }

    {
      sources && sources.length > 0 && (
        <section class="mt-16">
          <h2 class="mb-6 font-mono text-[15px] font-semibold tracking-[0.08em] text-faint">
            SOURCES &amp; PROOF
          </h2>
          <ul class="space-y-3">
            {sources.map((source, i) => (
              <li class="flex gap-3">
                <span class="font-mono text-accent">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <a
                  href={source.href}
                  class="text-accent no-underline hover:underline"
                >
                  {source.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <footer
      class="mt-16 flex flex-wrap items-center justify-between gap-4 border-t border-line pt-6"
    >
      <span class="font-mono text-[12.5px] text-faint">
        Drafted by my agents, edited by me.
      </span>
      <a
        href="/blog"
        class="font-mono text-[12.5px] text-accent no-underline hover:underline"
        >← All writing</a
      >
    </footer>
  </main>
</Base>
