---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base
  title="Writing — Pablo Albaladejo"
  description="Essays on building production software with AI agents: LLM evals, GEO, agentic development, and observability. Every claim links to a verifiable artifact."
  lang="en"
  path="/blog"
  active="writing"
  ogImage="/og/blog.png"
>
  <main class="mx-auto max-w-[70ch] pt-16 pb-24 min-[700px]:pt-[88px]">
    <h1
      class="mb-6 text-[38px] leading-[1.1] font-bold tracking-[-0.02em] text-pretty min-[700px]:text-[48px]"
    >
      Writing
    </h1>
    <p class="text-[19px] leading-[1.7] text-body text-pretty">
      Notes on building production software with AI agents — LLM evals, GEO,
      agentic development, and observability. Every claim links to a
      verifiable artifact.
    </p>

    <section class="mt-16">
      {
        posts.length === 0 ? (
          <p class="text-muted">No posts yet. Check back soon.</p>
        ) : (
          posts.map((post, i) => (
            <div
              class:list={[
                "flex items-baseline justify-between gap-6 border-t border-line py-5",
                i === posts.length - 1 && "border-b",
              ]}
            >
              <a
                href={`/blog/${post.id}`}
                class="text-[19px] font-bold text-ink no-underline text-pretty hover:underline"
              >
                {post.data.title}
              </a>
              <span class="font-mono text-[12.5px] whitespace-nowrap text-faint">
                {fmt(post.data.pubDate)}
              </span>
            </div>
          ))
        )
      }
    </section>
  </main>
</Base>
