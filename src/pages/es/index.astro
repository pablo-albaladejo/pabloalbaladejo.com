---
import Base from "../../layouts/Base.astro";

const projects = [
  {
    name: "Kaiord",
    href: "https://kaiord.com/es/",
    flagship: true,
    blurb:
      "Plataforma de entrenamiento open-source y local-first: calendario, asistente de IA, sincronización con Garmin y WHOOP, más SDK de TypeScript, CLI y servidor MCP para archivos FIT, TCX, ZWO y Garmin Connect. Cada línea escrita por agentes de IA.",
  },
  {
    name: "Deepgent",
    href: "https://deepgent.net",
    blurb:
      "Plataforma SaaS multi-tenant que da a cada empresa un chatbot de IA con su marca sobre su propia base de conocimiento curada: widget embebible, portal de autoservicio y RAG sobre AWS Bedrock. En producción.",
  },
  {
    name: "trainingpeaks-sdk",
    href: "https://github.com/pablo-albaladejo/trainingpeaks-sdk",
    blurb: "SDK de TypeScript para la plataforma TrainingPeaks.",
  },
  {
    name: "streaming-lambda-ai-sdk",
    href: "https://github.com/pablo-albaladejo/streaming-lambda-ai-sdk",
    blurb:
      "Respuestas estructuradas de LLM desde Amazon Bedrock (Claude) en streaming a través de AWS Lambda.",
  },
  {
    name: "tanita-to-garmin-cdk",
    href: "https://github.com/pablo-albaladejo/tanita-to-garmin-cdk",
    blurb:
      "App serverless en AWS (CDK + Step Functions) que sincroniza datos de composición corporal con Garmin Connect.",
  },
];
---

<Base
  title="Pablo Albaladejo — Construyo software de producción con agentes de IA"
  description="Ingeniero de software (AWS, TypeScript) que construye software de producción con agentes de IA — con evals de LLM, monitorización y observabilidad. Creador de Kaiord, la plataforma de entrenamiento open-source y local-first."
  lang="es"
  path="/es"
>
  <main class="mx-auto max-w-[70ch] pt-16 min-[700px]:pt-[88px]">
    <h1
      class="mb-7 text-[38px] leading-[1.1] font-bold tracking-[-0.02em] text-pretty min-[700px]:text-[52px]"
    >
      Construyo software de producción con agentes de IA.
    </h1>
    <p class="text-[19px] leading-[1.7] text-body text-pretty">
      Ingeniero senior de backend e IA (AWS, TypeScript) — 15+ años en SaaS,
      ahora en Aircall, donde mis sistemas procesan
      <strong class="text-ink">más de un millón de transcripciones de
      llamadas al día</strong>. En mi tiempo libre publico productos escritos
      de principio a fin con agentes de IA: CI estricto, specs y usuarios
      reales. Madrid, España.
    </p>
    <p class="mt-6 font-mono text-[13px] text-faint">
      A menudo mal escrito
      <span class="line-through decoration-accent">Albadalejo</span>; es
      Albaladejo.
    </p>

    <section class="mt-20">
      <h2
        class="mb-2 font-mono text-[15px] font-semibold tracking-[0.08em] text-faint"
      >
        PROYECTOS
      </h2>
      {
        projects.map((p, i) => (
          <div
            class:list={[
              "grid gap-2.5 border-t border-line py-6",
              i === projects.length - 1 && "border-b",
            ]}
          >
            <div class="flex flex-wrap items-baseline gap-3">
              <a
                href={p.href}
                class:list={[
                  "font-bold tracking-[-0.01em] text-ink no-underline hover:underline",
                  p.flagship ? "text-2xl" : "text-[19px]",
                ]}
              >
                {p.name}
              </a>
              {p.flagship && (
                <span class="rounded-full border border-line-2 px-2.5 py-0.5 font-mono text-[11.5px] text-accent">
                  FLAGSHIP
                </span>
              )}
            </div>
            <p class="m-0 text-[16px] leading-[1.65] text-body text-pretty">
              {p.blurb}
            </p>
          </div>
        ))
      }
    </section>

    <section class="mt-[72px] pb-24">
      <h2
        class="mb-5 font-mono text-[15px] font-semibold tracking-[0.08em] text-faint"
      >
        EN OTROS SITIOS
      </h2>
      <nav class="flex flex-wrap gap-6 font-mono text-[13.5px]">
        <a
          href="https://github.com/pablo-albaladejo"
          class="text-accent no-underline hover:underline">GitHub</a
        >
        <a
          href="https://linkedin.com/in/pabloalbaladejomestre"
          class="text-accent no-underline hover:underline">LinkedIn</a
        >
        <a
          href="https://stackoverflow.com/users/3395884/pablo-albaladejo"
          class="text-accent no-underline hover:underline">Stack Overflow</a
        >
        <a
          href="mailto:pablo.albaladejo.mestre@gmail.com"
          class="text-accent no-underline hover:underline">Email</a
        >
        <a
          href="https://kaiord.com/es/"
          class="text-accent no-underline hover:underline">kaiord.com</a
        >
      </nav>
    </section>
  </main>
</Base>
