---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { externalWriting, fmtMonthYear } from "../data/external-writing";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Pablo Albaladejo",
  alternateName: ["Pablo Albaladejo Mestre", "Pablo Albadalejo"],
  url: "https://pabloalbaladejo.com/",
  jobTitle: "AI Engineer",
  worksFor: { "@type": "Organization", name: "Aircall" },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Madrid",
    addressCountry: "ES",
  },
  description:
    "AI Engineer — production LLM systems, agents and infrastructure (AWS, TypeScript). Building software with AI agents; LLM evals, monitoring and observability. Creator of Kaiord.",
  knowsAbout: [
    "AI agents",
    "LLM evaluation",
    "LLM observability",
    "RAG",
    "AI infrastructure",
    "AWS",
    "TypeScript",
    "Production AI systems",
  ],
  sameAs: [
    "https://github.com/pablo-albaladejo",
    "https://linkedin.com/in/pabloalbaladejomestre",
    "https://stackoverflow.com/users/3395884/pablo-albaladejo",
    "https://kaiord.com",
  ],
});

const projects = [
  {
    name: "Kaiord",
    href: "https://kaiord.com",
    flagship: true,
    blurb:
      "Open-source, local-first training platform: calendar, AI assistant, Garmin & WHOOP sync, plus a TypeScript SDK, CLI, and MCP server for FIT, TCX, ZWO, and Garmin Connect files. Every line written by AI agents.",
  },
  {
    name: "Deepgent",
    href: "https://deepgent.net",
    blurb:
      "Multi-tenant SaaS: branded AI chatbot over a curated knowledge base — embeddable widget, self-service portal, RAG on AWS Bedrock. Live in production.",
  },
  {
    name: "trainingpeaks-sdk",
    href: "https://github.com/pablo-albaladejo/trainingpeaks-sdk",
    blurb: "TypeScript SDK for the TrainingPeaks platform.",
  },
  {
    name: "streaming-lambda-ai-sdk",
    href: "https://github.com/pablo-albaladejo/streaming-lambda-ai-sdk",
    blurb:
      "Structured LLM responses from Amazon Bedrock (Claude) streamed through AWS Lambda.",
  },
  {
    name: "tanita-to-garmin-cdk",
    href: "https://github.com/pablo-albaladejo/tanita-to-garmin-cdk",
    blurb:
      "Serverless AWS app (CDK + Step Functions) syncing body-composition data into Garmin Connect.",
  },
];

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base
  title="Pablo Albaladejo — I build production software with AI agents"
  description="AI Engineer — production LLM systems, agents & infrastructure (AWS, TypeScript). Building software with AI agents; LLM evals, monitoring & observability. Creator of Kaiord."
  lang="en"
  path="/"
  ogImage="/og/index.png"
>
  <script
    type="application/ld+json"
    set:html={personJsonLd}
    slot="head"
  />

  <main class="mx-auto max-w-[70ch] pt-16 min-[700px]:pt-[88px]">
    <h1
      class="mb-7 text-[38px] leading-[1.1] font-bold tracking-[-0.02em] text-pretty min-[700px]:text-[52px]"
    >
      I build production software with AI&nbsp;agents.
    </h1>
    <p class="text-[19px] leading-[1.7] text-body text-pretty">
      AI Engineer — production LLM systems, agents &amp; infrastructure.
      17+ years in SaaS (AWS, TypeScript), now at Aircall, where my systems
      process
      <strong class="text-ink">1M+ call transcriptions a day</strong>. On my
      own time I ship products written end to end with AI agents: strict
      CI, specs, real users, and the LLM evals, monitoring &amp;
      observability that keep them honest. Madrid, Spain.
    </p>
    <p class="mt-6 font-mono text-[13px] text-faint">
      Triathlete when I'm not shipping.
    </p>

    <section class="mt-20">
      <h2
        class="mb-2 font-mono text-[15px] font-semibold tracking-[0.08em] text-faint"
      >
        PROJECTS
      </h2>
      {
        projects.map((p, i) => (
          <div
            class:list={[
              "grid gap-2.5 border-t border-line py-6",
              i === projects.length - 1 && "border-b",
            ]}
          >
            <div class="flex flex-wrap items-baseline gap-3">
              <a
                href={p.href}
                class:list={[
                  "font-bold tracking-[-0.01em] text-ink no-underline hover:underline",
                  p.flagship ? "text-2xl" : "text-[19px]",
                ]}
              >
                {p.name}
              </a>
              {p.flagship && (
                <span class="rounded-full border border-line-2 px-2.5 py-0.5 font-mono text-[11.5px] text-accent">
                  FLAGSHIP
                </span>
              )}
            </div>
            <p class="m-0 text-[16px] leading-[1.65] text-body text-pretty">
              {p.blurb}
            </p>
          </div>
        ))
      }
    </section>

    <section class="mt-[72px]">
      <h2
        class="mb-2 font-mono text-[15px] font-semibold tracking-[0.08em] text-faint"
      >
        WRITING
      </h2>
      {
        posts.map((post, i) => (
          <div
            class:list={[
              "flex items-baseline justify-between gap-6 border-t border-line py-5",
              i === posts.length - 1 && "border-b",
            ]}
          >
            <a
              href={`/blog/${post.id}`}
              class="text-[19px] font-bold text-ink no-underline text-pretty hover:underline"
            >
              {post.data.title}
            </a>
            <time
              datetime={post.data.pubDate.toISOString()}
              class="font-mono text-[12.5px] whitespace-nowrap text-faint"
            >
              {fmt(post.data.pubDate)}
            </time>
          </div>
        ))
      }
      <p
        class="mt-8 mb-1 font-mono text-[12px] tracking-[0.08em] text-faint"
      >
        ALSO PUBLISHED
      </p>
      {
        externalWriting.map((piece) => (
          <div class="flex items-baseline justify-between gap-6 border-t border-line py-4">
            <a
              href={piece.href}
              target="_blank"
              rel="noopener"
              class="text-[16px] font-semibold text-ink no-underline text-pretty hover:underline"
            >
              {piece.title}{" "}
              <span class="font-mono text-[11.5px] whitespace-nowrap text-faint">
                ↗ {piece.venue}
              </span>
            </a>
            <time
              datetime={piece.iso}
              class="font-mono text-[12px] whitespace-nowrap text-faint"
            >
              {fmtMonthYear(piece.iso)}
            </time>
          </div>
        ))
      }
      <p class="mt-5">
        <a
          href="/blog"
          class="font-mono text-[13px] text-accent no-underline hover:underline"
          >All writing →</a
        >
      </p>
    </section>

    <section class="mt-[72px] pb-24">
      <h2
        class="mb-5 font-mono text-[15px] font-semibold tracking-[0.08em] text-faint"
      >
        ELSEWHERE
      </h2>
      <nav class="flex flex-wrap gap-6 font-mono text-[13.5px]">
        <a
          href="https://github.com/pablo-albaladejo"
          class="text-accent no-underline hover:underline">GitHub</a
        >
        <a
          href="https://linkedin.com/in/pabloalbaladejomestre"
          class="text-accent no-underline hover:underline">LinkedIn</a
        >
        <a
          href="https://stackoverflow.com/users/3395884/pablo-albaladejo"
          class="text-accent no-underline hover:underline">Stack Overflow</a
        >
        <a
          href="https://linkedin.com/in/pabloalbaladejomestre"
          data-email="pablo.albaladejo.mestre"
          data-domain="gmail.com"
          class="text-accent no-underline hover:underline">Email</a
        >
        <a
          href="https://kaiord.com"
          class="text-accent no-underline hover:underline">kaiord.com</a
        >
      </nav>
    </section>
  </main>
</Base>
