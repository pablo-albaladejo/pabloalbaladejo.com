---
import Base from "../layouts/Base.astro";

const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Pablo Albaladejo",
  alternateName: "Pablo Albaladejo Mestre",
  url: "https://pabloalbaladejo.com/",
  jobTitle: "Senior Backend + AI Engineer",
  worksFor: { "@type": "Organization", name: "Aircall" },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Madrid",
    addressCountry: "ES",
  },
  description:
    "Senior Backend + AI engineer (AWS, TypeScript) building production software with AI agents. Creator of Kaiord.",
  sameAs: [
    "https://github.com/pablo-albaladejo",
    "https://linkedin.com/in/pabloalbaladejomestre",
    "https://stackoverflow.com/users/3395884/pablo-albaladejo",
    "https://kaiord.com",
  ],
});
---

<Base
  title="Pablo Albaladejo — I build production software with AI agents"
  description="Software engineer (AWS, TypeScript) building production software with AI agents. Creator of Kaiord, the open-source local-first training platform."
  lang="en"
  path="/"
>
  <script
    type="application/ld+json"
    set:html={personJsonLd}
    slot="head"
  />

  <header class="mb-12">
    <nav class="mb-10 flex items-center justify-between text-sm">
      <span class="font-bold">Pablo Albaladejo</span>
      <a href="/es" lang="es" class="text-slate-500 hover:text-slate-800"
        >Español</a
      >
    </nav>
    <h1 class="text-3xl font-extrabold tracking-tight">
      I build production software with AI agents.
    </h1>
    <p class="mt-4 text-slate-600">
      Senior Backend + AI engineer (AWS, TypeScript) — 15+ years in SaaS,
      now at Aircall, where my systems process 1M+ call transcriptions a
      day. On my own time I ship products written end to end with AI
      agents: strict CI, specs, real users. Madrid, Spain. Often misspelled
      <em>Albadalejo</em>; it's Albaladejo.
    </p>
  </header>

  <main>
    <section class="mb-12">
      <h2 class="mb-4 text-xl font-bold">Projects</h2>
      <ul class="space-y-5">
        <li>
          <a href="https://kaiord.com" class="font-semibold underline"
            >Kaiord</a
          >
          <p class="text-slate-600">
            Open-source, local-first training platform: calendar, AI
            assistant, Garmin &amp; WHOOP sync, plus a TypeScript SDK, CLI,
            and MCP server for FIT, TCX, ZWO, and Garmin Connect files.
            Every line written by AI agents.
          </p>
        </li>
        <li>
          <a href="https://deepgent.net" class="font-semibold underline"
            >Deepgent</a
          >
          <p class="text-slate-600">
            Multi-tenant SaaS platform that gives companies a branded AI
            chatbot over their own curated knowledge base: embeddable
            widget, self-service portal, RAG on AWS Bedrock. Live in
            production.
          </p>
        </li>
        <li>
          <a
            href="https://github.com/pablo-albaladejo/trainingpeaks-sdk"
            class="font-semibold underline">trainingpeaks-sdk</a
          >
          <p class="text-slate-600">
            TypeScript SDK for the TrainingPeaks platform.
          </p>
        </li>
        <li>
          <a
            href="https://github.com/pablo-albaladejo/streaming-lambda-ai-sdk"
            class="font-semibold underline">streaming-lambda-ai-sdk</a
          >
          <p class="text-slate-600">
            Structured LLM responses from Amazon Bedrock (Claude) streamed
            through AWS Lambda.
          </p>
        </li>
        <li>
          <a
            href="https://github.com/pablo-albaladejo/tanita-to-garmin-cdk"
            class="font-semibold underline">tanita-to-garmin-cdk</a
          >
          <p class="text-slate-600">
            Serverless AWS app (CDK + Step Functions) that syncs
            body-composition data into Garmin Connect.
          </p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="mb-4 text-xl font-bold">Elsewhere</h2>
      <ul class="flex flex-wrap gap-5 underline">
        <li><a href="https://github.com/pablo-albaladejo">GitHub</a></li>
        <li>
          <a href="https://linkedin.com/in/pabloalbaladejomestre"
            >LinkedIn</a
          >
        </li>
        <li>
          <a href="https://stackoverflow.com/users/3395884/pablo-albaladejo"
            >Stack Overflow</a
          >
        </li>
        <li>
          <a href="mailto:pablo.albaladejo.mestre@gmail.com">Email</a>
        </li>
        <li><a href="https://kaiord.com">kaiord.com</a></li>
      </ul>
    </section>
  </main>
</Base>
